{
  // 只读联调环境：
  // - 允许从远端 Oracle 拉取数据到本地 SQL Server
  // - 禁止状态驱动同步回写远端
  // - 禁止业务回传与失败补偿回写远端
  "Oracle": {
    "ReadOnly": true
  },
  "SyncJob": {
    "PollingIntervalSeconds": 10,
    "MaxParallelTables": 2,
    "TableSyncTimeoutSeconds": 3600,
    "Tables": [
      {
        "ShouldWriteBackRemoteStatus": false,
        "IgnorePendingStatusValue": true,
        "StatusBatchSize": 2000
      },
      {
        "ShouldWriteBackRemoteStatus": false,
        "IgnorePendingStatusValue": true,
        "StatusBatchSize": 2000
      }
    ]
  },
  "QueryCache": {
    "AggregateTimeBucketSeconds": 5,
    "GlobalDashboardSeconds": 5
  },
  "DashboardSnapshot": {
    "Enabled": true,
    "PreferSnapshotQueries": true,
    "AllowBaseTableFallback": true,
    "RefreshIntervalSeconds": 5,
    "ForceInitialFullRefresh": true
  },
  "WmsFeedback": {
    "Enabled": false
  },
  "FeedbackCompensationJob": {
    "Enabled": false
  }
}
