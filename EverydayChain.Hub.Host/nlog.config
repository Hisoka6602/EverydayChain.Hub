<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

	<targets>
		<!-- 控制台输出 -->
		<target xsi:type="ColoredConsole"
				name="console"
				layout="${longdate} [${level:uppercase=true}] ${logger} - ${message}${onexception:inner=${newline}${exception:format=tostring}}" />

		<!-- 滚动文件输出（按日切割，并限制单文件最大 10 MB）；keepFileOpen+autoFlush 保证每条日志立即落盘 -->
		<target xsi:type="File"
				name="file"
				fileName="${basedir}/logs/hub-${shortdate}.log"
				layout="${longdate} [${level:uppercase=true}] ${logger} - ${message}${onexception:inner=${newline}${exception:format=tostring}}"
				archiveEvery="Day"
				archiveNumbering="Date"
				maxArchiveFiles="30"
				archiveAboveSize="10485760"
				encoding="utf-8"
				keepFileOpen="true"
				autoFlush="true" />

		<!-- 同步数据专属滚动文件（按日切割，单文件上限 10 MB，保留 30 天）；
		     仅写入同步链路相关组件日志，与通用日志文件互不干扰，便于独立分析性能问题 -->
		<target xsi:type="File"
				name="sync-file"
				fileName="${basedir}/logs/sync-${shortdate}.log"
				layout="${longdate} [${level:uppercase=true}] ${logger} - ${message}${onexception:inner=${newline}${exception:format=tostring}}"
				archiveEvery="Day"
				archiveNumbering="Date"
				maxArchiveFiles="30"
				archiveAboveSize="10485760"
				encoding="utf-8"
				keepFileOpen="true"
				autoFlush="true" />
	</targets>

	<rules>
		<!--
      抑制 Microsoft.* 框架日志中低于 Warn 的噪声级别。
      final="true" 表示命中此规则后立即停止后续规则匹配，使 Trace/Debug/Info 级别的框架日志
      不再流入下方的通配规则，从而避免写入控制台和文件。
      Warn/Error/Fatal 级别不在 maxlevel="Info" 范围内，会继续流入下一条规则正常落盘。
    -->
		<logger name="Microsoft.*" maxlevel="Info" final="true" />
		<!--
      同步链路专属日志路由：将同步后台任务、编排服务、执行服务、基础设施同步组件的日志
      额外路由至 sync-file，不设 final="true"，日志同时流入下方通配规则写入 file 与 console，
      保证通用日志文件完整性的同时在同步专属文件中聚合所有同步步骤耗时信息。
      当前命中类：SyncBackgroundWorker；SyncOrchestrator / SyncExecutionService / DeletionExecutionService
      （Application.Services.*）；RemoteStatusConsumeService / OracleStatusDrivenSourceReader /
      OracleRemoteStatusWriter / SqlServerAppendOnlyWriter（Infrastructure.Sync.*）；
      OracleSourceReader（精确匹配）；SqlServerSyncUpsertRepository / SyncStagingRepository /
      SyncDeletionRepository / SyncCheckpointRepository / SyncTaskConfigRepository（*Sync* 通配）。
    -->
		<logger name="EverydayChain.Hub.Host.Workers.SyncBackgroundWorker" minlevel="Info" writeTo="sync-file" />
		<logger name="EverydayChain.Hub.Host.Workers.FeedbackCompensationBackgroundWorker" minlevel="Info" writeTo="sync-file" />
		<logger name="EverydayChain.Hub.Application.Services.*" minlevel="Info" writeTo="sync-file" />
		<logger name="EverydayChain.Hub.Infrastructure.Sync.*" minlevel="Info" writeTo="sync-file" />
		<logger name="EverydayChain.Hub.Infrastructure.Repositories.OracleSourceReader" minlevel="Info" writeTo="sync-file" />
		<!-- 匹配含 Sync 字样的仓储类（SqlServerSyncUpsertRepository / SyncStagingRepository / SyncDeletionRepository / SyncCheckpointRepository / SyncTaskConfigRepository）-->
		<logger name="EverydayChain.Hub.Infrastructure.Repositories.*Sync*" minlevel="Info" writeTo="sync-file" />
		<!-- 全部应用日志 Info 及以上同时写入控制台与滚动文件 -->
		<logger name="*" minlevel="Info" writeTo="console,file" />
	</rules>
</nlog>
