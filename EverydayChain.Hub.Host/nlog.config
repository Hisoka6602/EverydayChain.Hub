<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

  <targets>
    <!-- 控制台输出 -->
    <target xsi:type="ColoredConsole"
            name="console"
            layout="${longdate} [${level:uppercase=true}] ${logger} - ${message}${onexception:inner=${newline}${exception:format=tostring}}" />

    <!-- 滚动文件输出（按日切割，并限制单文件最大 100 MB）；keepFileOpen+autoFlush 保证每条日志立即落盘 -->
    <target xsi:type="File"
            name="file"
            fileName="${basedir}/logs/hub-${shortdate}.log"
            layout="${longdate} [${level:uppercase=true}] ${logger} - ${message}${onexception:inner=${newline}${exception:format=tostring}}"
            archiveEvery="Day"
            archiveNumbering="Date"
            maxArchiveFiles="30"
            archiveAboveSize="104857600"
            encoding="utf-8"
            keepFileOpen="true"
            autoFlush="true"
            concurrentWrites="true" />
  </targets>

  <rules>
    <!--
      抑制 Microsoft.* 框架日志中低于 Warn 的噪声级别。
      final="true" 表示命中此规则后立即停止后续规则匹配，使 Trace/Debug/Info 级别的框架日志
      不再流入下方的通配规则，从而避免写入控制台和文件。
      Warn/Error/Fatal 级别不在 maxlevel="Info" 范围内，会继续流入下一条规则正常落盘。
    -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <!-- 全部应用日志 Info 及以上同时写入控制台与滚动文件 -->
    <logger name="*" minlevel="Info" writeTo="console,file" />
  </rules>

</nlog>
