<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

	<targets>
		<!-- 控制台输出 -->
		<target xsi:type="ColoredConsole"
				name="console"
				layout="${longdate} [${level:uppercase=true}] ${logger} - ${message}${onexception:inner=${newline}${exception:format=tostring}}" />

		<!-- 滚动文件输出，按日切割并限制单文件上限 10 MB；keepFileOpen 与 autoFlush 用于保证日志及时落盘 -->
		<target xsi:type="File"
				name="file"
				fileName="${basedir}/logs/hub-${shortdate}.log"
				layout="${longdate} [${level:uppercase=true}] ${logger} - ${message}${onexception:inner=${newline}${exception:format=tostring}}"
				archiveEvery="Day"
				archiveNumbering="Date"
				maxArchiveFiles="30"
				archiveAboveSize="10485760"
				encoding="utf-8"
				keepFileOpen="true"
				autoFlush="true" />

		<!-- 同步链路专属滚动文件，按日切割并限制单文件上限 10 MB，保留 30 天 -->
		<target xsi:type="File"
				name="sync-file"
				fileName="${basedir}/logs/sync-${shortdate}.log"
				layout="${longdate} [${level:uppercase=true}] ${logger} - ${message}${onexception:inner=${newline}${exception:format=tostring}}"
				archiveEvery="Day"
				archiveNumbering="Date"
				maxArchiveFiles="30"
				archiveAboveSize="10485760"
				encoding="utf-8"
				keepFileOpen="true"
				autoFlush="true" />

		<!-- API 失败请求与响应专属滚动文件，按日切割并限制单文件上限 10 MB，保留 30 天 -->
		<target xsi:type="File"
				name="api-failure-file"
				fileName="${basedir}/logs/api-failure-${shortdate}.log"
				layout="${longdate} [${level:uppercase=true}] ${logger} - ${message}${onexception:inner=${newline}${exception:format=tostring}}"
				archiveEvery="Day"
				archiveNumbering="Date"
				maxArchiveFiles="30"
				archiveAboveSize="10485760"
				encoding="utf-8"
				keepFileOpen="true"
				autoFlush="true" />
	</targets>

	<rules>
		<!-- 抑制 Microsoft.* 框架日志中低于 Warn 的噪声级别，命中后不再继续匹配后续规则 -->
		<logger name="Microsoft.*" maxlevel="Info" final="true" />

		<!-- 同步链路专属路由，同时保留在通用日志中，便于统一排障 -->
		<logger name="EverydayChain.Hub.Host.Workers.SyncBackgroundWorker" minlevel="Info" writeTo="sync-file" />
		<logger name="EverydayChain.Hub.Host.Workers.FeedbackCompensationBackgroundWorker" minlevel="Info" writeTo="sync-file" />
		<logger name="EverydayChain.Hub.Application.Services.*" minlevel="Info" writeTo="sync-file" />
		<logger name="EverydayChain.Hub.Infrastructure.Sync.*" minlevel="Info" writeTo="sync-file" />
		<logger name="EverydayChain.Hub.Infrastructure.Repositories.OracleSourceReader" minlevel="Info" writeTo="sync-file" />
		<!-- 匹配名称中包含 Sync 的仓储类日志 -->
		<logger name="EverydayChain.Hub.Infrastructure.Repositories.*Sync*" minlevel="Info" writeTo="sync-file" />

		<!-- 分表治理日志统一输出到控制台与通用滚动文件 -->
		<logger name="EverydayChain.Hub.Infrastructure.Services.Sharding.*" minlevel="Info" writeTo="console,file" final="true" />

		<!-- API 失败中间件单独写入失败日志文件 -->
		<logger name="EverydayChain.Hub.Host.Middlewares.ApiFailureLoggingMiddleware" minlevel="Error" writeTo="api-failure-file" final="true" />

		<!-- 全部应用日志同时输出到控制台与通用滚动文件 -->
		<logger name="*" minlevel="Info" writeTo="console,file" />
	</rules>
</nlog>
