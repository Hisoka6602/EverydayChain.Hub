{
  // 开发环境配置：通常仅覆盖与调试相关的最小配置。
  "Logging": {
    // 日志级别映射（取值示例：Trace/Debug/Information/Warning/Error/Critical/None）。
    "LogLevel": {
      // 默认日志级别。
      "Default": "Information",
      // Host 生命周期日志级别。
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  // 开发环境远端 Oracle 覆盖配置。
  "Oracle": {
    // 开发环境 Oracle 连接字符串（Oracle 标准连接字符串；示例中的 ORACLE_PASSWORD 仅为占位符，需由 UserSecrets 或环境变量在启动前替换，禁止提交真实密码）。
    "ConnectionString": "Data Source=127.0.0.1:1521/ORCLPDB1;User Id=readonly_user;Password=ORACLE_PASSWORD;Pooling=true;",
    // 开发环境默认源端 Schema（Oracle 有效 Schema 名称）。
    "DefaultSchema": "EXT",
    // 开发环境是否强制只读（可填写项：true、false；建议 true）。
    "ReadOnly": true,
    // 开发环境数据库命令超时秒数（建议范围：1~3600）。
    "CommandTimeoutSeconds": 60,
    // 开发环境分页读取允许的最大 PageSize（建议范围：1~100000）。
    "MaxPageSize": 5000
  }
}
