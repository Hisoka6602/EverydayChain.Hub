{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Worker": {
    "PollingIntervalSeconds": 10
  },
  "Sharding": {
    "ConnectionString": "Server=localhost,1433;Database=EverydayChainHub;User Id=sa;Password=Your_password123;TrustServerCertificate=true",
    "Schema": "dbo",
    "BaseTableName": "sorting_task_trace",
    "AutoCreateMonthsAhead": 1
  },
  "AutoTune": {
    "Enabled": true,
    "InitialBatchSize": 200,
    "MinBatchSize": 20,
    "MaxBatchSize": 2000,
    "IncreaseStep": 50,
    "DecreaseStep": 100,
    "SlowThresholdMilliseconds": 400,
    "SamplingWindowSize": 10,
    "FailureRateThreshold": 0.2
  },
  "DangerZone": {
    "TimeoutSeconds": 30,
    "MaxRetryAttempts": 2,
    "RetryBaseDelaySeconds": 1,
    "CircuitBreakerFailureRatio": 0.5,
    "CircuitBreakerMinimumThroughput": 10,
    "CircuitBreakerSamplingDurationMinutes": 1,
    "CircuitBreakerBreakDurationSeconds": 20
  },
  "SyncJob": {
    "PollingIntervalSeconds": 60,
    "DefaultMaxLagMinutes": 10,
    "MaxParallelTables": 2,
    "CheckpointFilePath": "data/sync-checkpoints.json",
    "TargetStoreFilePath": "data/sync-target-store.json",
    "Tables": [
      {
        "TableCode": "SortingTaskTrace",
        "Enabled": true,
        "SourceSchema": "EXT",
        "SourceTable": "T_SORTING_TASK_TRACE",
        "TargetLogicalTable": "sorting_task_trace",
        "CursorColumn": "LastModifiedTime",
        "StartTimeLocal": "2026-03-01 00:00:00",
        "PageSize": 10,
        "PollingIntervalSeconds": 30,
        "MaxLagMinutes": 10,
        "Priority": "High",
        "UniqueKeys": [
          "BusinessNo"
        ],
        "ExcludedColumns": [],
        "Delete": {
          "Policy": "Disabled",
          "Enabled": false,
          "DryRun": true,
          "CompareSegmentSize": 20000,
          "CompareMaxParallelism": 4
        },
        "Retention": {
          "Enabled": true,
          "KeepMonths": 3,
          "DryRun": true,
          "AllowDrop": false
        }
      }
    ]
  },
  "RetentionJob": {
    "Enabled": true,
    "PollingIntervalSeconds": 3600,
    "AllowDangerousAction": false
  }
}
